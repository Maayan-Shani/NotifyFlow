<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nf_demo_background"
    android:layoutDirection="ltr"
    android:textDirection="ltr">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/nf_space_screen"
        android:layoutDirection="ltr"
        android:textDirection="ltr">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/profile"
            android:textSize="@dimen/nf_text_size_screen_title"
            android:textStyle="bold"
            android:textColor="@color/nf_text_primary"
            android:gravity="left"
            android:layout_marginBottom="@dimen/nf_space_xs"
            android:layoutDirection="ltr"
            android:textDirection="ltr" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/user_profile_and_preferences"
            android:textSize="@dimen/nf_text_size_body"
            android:textColor="@color/nf_text_secondary"
            android:gravity="left"
            android:layout_marginBottom="@dimen/nf_space_4xl"
            android:layoutDirection="ltr"
            android:textDirection="ltr" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/nf_space_3xl"
            app:cardCornerRadius="@dimen/nf_space_4xl"
            app:cardElevation="@dimen/nf_space_xxs"
            app:strokeColor="@color/nf_primary_light"
            app:strokeWidth="@dimen/nf_card_stroke_width"
            app:cardBackgroundColor="@color/nf_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/nf_space_screen"
                android:layoutDirection="ltr"
                android:textDirection="ltr">


                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/demo_user"
                    android:textSize="@dimen/nf_text_size_card_title_large"
                    android:textStyle="bold"
                    android:textColor="@color/nf_text_primary"
                    android:gravity="center"
                    android:layout_marginBottom="@dimen/nf_space_xxs"
                    android:layoutDirection="ltr"
                    android:textDirection="ltr" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/connected_to_notifyflow_sdk"
                    android:textSize="@dimen/nf_text_size_body_small"
                    android:textColor="@color/nf_text_secondary"
                    android:gravity="center"
                    android:layoutDirection="ltr"
                    android:textDirection="ltr" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/nf_space_3xl"
            app:cardElevation="@dimen/nf_card_elevation_small"
            app:cardBackgroundColor="@color/nf_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/nf_space_3xl"
                android:layoutDirection="ltr"
                android:textDirection="ltr">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_details"
                    android:textSize="@dimen/nf_text_size_section_title"
                    android:textStyle="bold"
                    android:textColor="@color/nf_text_primary"
                    android:layout_marginBottom="@dimen/nf_space_xl"
                    android:layoutDirection="ltr"
                    android:textDirection="ltr" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/notifications_on_this_screen_are_triggered_using_the_profile_screen_key"
                    android:textSize="@dimen/nf_text_size_body"
                    android:textColor="@color/nf_text_secondary"
                    android:lineSpacingExtra="@dimen/nf_space_xxs"
                    android:layoutDirection="ltr"
                    android:textDirection="ltr" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/profile_screen_key_profile_screen"
            android:textSize="@dimen/nf_text_size_badge"
            android:textColor="@color/nf_primary"
            android:gravity="center"
            android:layout_marginTop="@dimen/nf_space_3xl"
            android:layoutDirection="ltr"
            android:textDirection="ltr" />

    </LinearLayout>

</ScrollView>