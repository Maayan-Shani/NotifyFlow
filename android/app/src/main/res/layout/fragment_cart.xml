<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nf_demo_background"
    android:layoutDirection="ltr"
    android:textDirection="ltr">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/nf_space_screen"
        android:layoutDirection="ltr"
        android:textDirection="ltr">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/cart"
            android:textSize="@dimen/nf_text_size_screen_title"
            android:textStyle="bold"
            android:textColor="@color/nf_text_primary"
            android:gravity="left"
            android:layout_marginBottom="@dimen/nf_space_xs"
            android:layoutDirection="ltr"
            android:textDirection="ltr" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/review_your_selected_items"
            android:textSize="@dimen/nf_text_size_body"
            android:textColor="@color/nf_text_secondary"
            android:gravity="left"
            android:layout_marginBottom="@dimen/nf_space_4xl"
            android:layoutDirection="ltr"
            android:textDirection="ltr" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/nf_space_3xl"
            app:cardCornerRadius="@dimen/nf_space_4xl"
            app:cardElevation="@dimen/nf_space_xxs"
            app:strokeColor="@color/nf_primary_light"
            app:strokeWidth="@dimen/nf_card_stroke_width"
            app:cardBackgroundColor="@color/nf_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/nf_space_card_large"
                android:layoutDirection="ltr"
                android:textDirection="ltr">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/your_cart_is_empty"
                    android:textSize="@dimen/nf_text_size_card_title_large"
                    android:textStyle="bold"
                    android:textColor="@color/nf_text_primary"
                    android:gravity="center"
                    android:layout_marginBottom="@dimen/nf_space_xs"
                    android:layoutDirection="ltr"
                    android:textDirection="ltr" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/notifyflow_can_display_cart_related_messages_when_this_screen_is_opened"
                    android:textSize="@dimen/nf_text_size_body"
                    android:textColor="@color/nf_text_secondary"
                    android:gravity="center"
                    android:lineSpacingExtra="@dimen/nf_space_xxs"
                    android:layoutDirection="ltr"
                    android:textDirection="ltr" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/nf_space_3xl"
            app:cardElevation="@dimen/nf_card_elevation_small"
            app:cardBackgroundColor="@color/nf_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/nf_space_3xl"
                android:layoutDirection="ltr"
                android:textDirection="ltr">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cart_summary"
                    android:textSize="@dimen/nf_text_size_section_title"
                    android:textStyle="bold"
                    android:textColor="@color/nf_text_primary"
                    android:layout_marginBottom="@dimen/nf_space_lg"
                    android:layoutDirection="ltr"
                    android:textDirection="ltr" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/items_0_nestimated_total_0_00_nscreen_key_cart_screen"
                    android:textSize="@dimen/nf_text_size_body"
                    android:textColor="@color/nf_text_secondary"
                    android:lineSpacingExtra="@dimen/nf_line_spacing_large"
                    android:layoutDirection="ltr"
                    android:textDirection="ltr" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>